# ===================================
# Vikamusk Website - Environment Variables
# ===================================

# SMTP Configuration for Nodemailer (Contact Form)
# Use Gmail: enable "App Passwords" in Google Account settings
# Or use any SMTP provider (SendGrid, Mailgun, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Recipient email for contact form submissions
CONTACT_EMAIL_TO=sales@vikamusk.com

# Admin Panel Credentials
ADMIN_USERNAME=aaaaaa
ADMIN_PASSWORD=aaaaaa
ADMIN_JWT_SECRET=abbbbgggg
